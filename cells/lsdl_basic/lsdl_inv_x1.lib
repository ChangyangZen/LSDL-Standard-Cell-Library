/* lsdl_inv_x1.lib — minimal Liberty for the LSDL inverter cell.
 *
 * Modeled as a positive-edge-triggered flop on Clk (per the plan and
 * paper Fig. 1). The cell's integrated latch captures the inverted
 * input on Clk rising; precharge happens during Clk low.
 *
 * Timing numbers come from the Track 1 PVT sweep at the slow corner
 * (SS / 125 C / 4.75 V): tpd_eval_lh = 339 ps + margin.
 *
 * Wave 0 minimum-viable Liberty: single delay number, no LUTs. A
 * proper characterized .lib with output-load × input-slew tables will
 * be generated by scripts/gen_liberty.py once the agent-driven sizing
 * loop produces final cell dimensions.
 */

library (lsdl_fd_sc_9t5v0) {
  technology ("cmos");
  delay_model : table_lookup;
  time_unit : "1ns";
  voltage_unit : "1V";
  current_unit : "1mA";
  pulling_resistance_unit : "1kohm";
  capacitive_load_unit (1, ff);
  leakage_power_unit : "1nW";

  nom_voltage : 5.0;
  nom_temperature : 25.0;
  nom_process : 1.0;

  voltage_map (VPWR, 5.0);
  voltage_map (VGND, 0.0);

  operating_conditions (typ_5p00_25C) {
    process : 1.0;
    voltage : 5.0;
    temperature : 25.0;
  }
  default_operating_conditions : typ_5p00_25C;

  /* ---------------------------------------------------------------- */
  cell (lsdl_inv_x1) {
    area : 12.0 ;  /* 11 devices * ~1.1 um^2 each = rough placeholder */

    pg_pin (VPWR) { pg_type : primary_power; voltage_name : VPWR; }
    pg_pin (VGND) { pg_type : primary_ground; voltage_name : VGND; }

    /* The cell's integrated latch behaves as a positive-edge flop on
       Clk whose data is the inverted A input — captured at eval. */
    ff ("IQ", "IQN") {
      clocked_on : "Clk";
      next_state : "A'";
    }

    /* Clk: cell's clock pin. SDC binds this to C1 or C2 at the
       pipeline-stage parity level. */
    pin (Clk) {
      direction : input;
      clock : true;
      capacitance : 4.0 ;
      related_power_pin : VPWR;
      related_ground_pin : VGND;
      /* Paper: glitch < 10% VDD requires bounded eval window. */
      min_pulse_width_high : 0.500 ;   /* eval window: >= tpd_eval + margin */
      min_pulse_width_low  : 0.400 ;   /* precharge window */
      min_period : 1.0 ;               /* derived from 1/Fmax target */
    }

    pin (A) {
      direction : input;
      capacitance : 2.5 ;
      related_power_pin : VPWR;
      related_ground_pin : VGND;
      timing () {
        related_pin : "Clk";
        timing_type : setup_rising;
        rise_constraint (scalar) { values ("0.150"); }
        fall_constraint (scalar) { values ("0.150"); }
      }
      timing () {
        related_pin : "Clk";
        timing_type : hold_rising;
        rise_constraint (scalar) { values ("0.050"); }
        fall_constraint (scalar) { values ("0.050"); }
      }
    }

    pin (Out) {
      direction : output;
      capacitance : 0.0 ;
      function : "IQ";
      max_capacitance : 50.0 ;
      related_power_pin : VPWR;
      related_ground_pin : VGND;
      /* Single Clk rising-edge -> Out arc.
         339 ps worst-case from PVT sweep; pad to 400 ps. */
      timing () {
        related_pin : "Clk";
        timing_type : rising_edge;
        timing_sense : non_unate;
        cell_rise (scalar) { values ("0.400"); }
        cell_fall (scalar) { values ("0.400"); }
        rise_transition (scalar) { values ("0.100"); }
        fall_transition (scalar) { values ("0.100"); }
      }
    }

    /* Pattern-independent placeholder; precharge + evaluate energy
       breakdown comes from characterization in Wave 1. */
    cell_leakage_power : 1.0 ;
  }
}
