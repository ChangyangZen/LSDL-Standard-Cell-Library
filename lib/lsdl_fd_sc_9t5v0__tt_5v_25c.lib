        timing_type   : setup_rising;
        rise_constraint (scalar) { values ("0.100"); }
        fall_constraint (scalar) { values ("0.100"); }
      }
      timing () {
        related_pin   : "CLK";
        timing_type   : hold_rising;
        rise_constraint (scalar) { values ("0.050"); }
        fall_constraint (scalar) { values ("0.050"); }
      }
    }
    pin (A4) {
      direction   : input;
      capacitance : 0.005;
      timing () {
        related_pin   : "CLK";
        timing_type   : setup_rising;
        rise_constraint (scalar) { values ("0.100"); }
        fall_constraint (scalar) { values ("0.100"); }
      }
      timing () {
        related_pin   : "CLK";
        timing_type   : hold_rising;
        rise_constraint (scalar) { values ("0.050"); }
        fall_constraint (scalar) { values ("0.050"); }
      }
    }
    ff ("IQ", "IQN") {
      clocked_on : "CLK";
      next_state : "!(A1 | A2 | A3 | A4)";
    }
    pin (OUT) {
      direction : output;
      function  : "IQ";
      timing () {
        related_pin : "CLK";
        timing_type : rising_edge;
        /* cell_fall = evaluate path (n-tree discharges, Out falls) */
        cell_fall (scalar) { values ("0.231"); }
        /* cell_rise = precharge+non-eval path (conservative = same) */
        cell_rise (scalar) { values ("0.050"); }
        fall_transition (scalar) { values ("0.040"); }
        rise_transition (scalar) { values ("0.040"); }
      }
    }
    pin (VPWR) {
      direction : inout;
      pg_type   : primary_power;
    }
    pin (VGND) {
      direction : inout;
      pg_type   : primary_ground;
    }
    cell_leakage_power : 0.100;
  }

}
