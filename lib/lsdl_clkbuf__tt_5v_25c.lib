library (lsdl_clkbuf) {
  technology (cmos);
  delay_model : table_lookup;
  time_unit : "1ns"; voltage_unit : "1V"; current_unit : "1mA";
  capacitive_load_unit (1, pf); pulling_resistance_unit : "1kohm";
  leakage_power_unit : "1nW";
  nom_process : 1; nom_voltage : 5.0; nom_temperature : 25;
  voltage_map (VPWR, 5.0);
  voltage_map (VGND, 0.0);
  input_threshold_pct_rise : 50; input_threshold_pct_fall : 50;
  output_threshold_pct_rise : 50; output_threshold_pct_fall : 50;
  slew_lower_threshold_pct_rise : 20; slew_upper_threshold_pct_rise : 80;
  slew_lower_threshold_pct_fall : 20; slew_upper_threshold_pct_fall : 80;
  lu_table_template (del_3x3) {
    variable_1 : input_net_transition;
    variable_2 : total_output_net_capacitance;
    index_1 ("0.020, 0.100, 0.400");
    index_2 ("0.002, 0.020, 0.080");
  }
  cell (lsdl_clkbuf_x1) {
    area : 31.0;
    pg_pin (VPWR) { voltage_name : VPWR; pg_type : primary_power; }
    pg_pin (VGND) { voltage_name : VGND; pg_type : primary_ground; }
    pin (A) { direction : input; capacitance : 0.003; related_power_pin : VPWR; related_ground_pin : VGND; }
    pin (Z) {
      direction : output; function : "A"; max_capacitance : 0.20;
      related_power_pin : VPWR; related_ground_pin : VGND;
      timing () {
        related_pin : "A"; timing_sense : positive_unate;
        cell_rise  (del_3x3) { index_1("0.020,0.100,0.400"); index_2("0.002,0.020,0.080");
          values ("0.06,0.12,0.30","0.09,0.15,0.33","0.18,0.24,0.42"); }
        cell_fall  (del_3x3) { index_1("0.020,0.100,0.400"); index_2("0.002,0.020,0.080");
          values ("0.06,0.12,0.30","0.09,0.15,0.33","0.18,0.24,0.42"); }
        rise_transition (del_3x3) { index_1("0.020,0.100,0.400"); index_2("0.002,0.020,0.080");
          values ("0.04,0.10,0.30","0.05,0.11,0.31","0.07,0.13,0.33"); }
        fall_transition (del_3x3) { index_1("0.020,0.100,0.400"); index_2("0.002,0.020,0.080");
          values ("0.04,0.10,0.30","0.05,0.11,0.31","0.07,0.13,0.33"); }
      }
    }
  }
}
